# ============================================================
# Happi Secretary — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# App
DEBUG=false
SECRET_KEY=change-me-in-production

# ---- AI ----
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# ---- Vapi.ai (telephony) ----
# Get your keys at https://vapi.ai
VAPI_API_KEY=
VAPI_PHONE_NUMBER_ID=
VAPI_WEBHOOK_SECRET=

# ---- Voice & STT ----
# ElevenLabs: https://elevenlabs.io
ELEVENLABS_API_KEY=
ELEVENLABS_DEFAULT_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# Deepgram: https://deepgram.com
DEEPGRAM_API_KEY=

# ---- Calendar ----
# Cal.com: https://cal.com/settings/developer/api-keys
CALCOM_API_KEY=
CALCOM_API_URL=https://api.cal.com/v2

# ---- Notifications ----
# Resend (email): https://resend.com
RESEND_API_KEY=

# Twilio (SMS): https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+33...

# ---- Frontend ----
DASHBOARD_URL=http://localhost:3001
CORS_ORIGINS=["http://localhost:3001"]
